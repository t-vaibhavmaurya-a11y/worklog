# Copy to ~/.cursor/credentials.env (never commit the real file).
# Jira
JIRA_SITE_URL=https://your-domain.atlassian.net
JIRA_USER_EMAIL=you@company.com
JIRA_API_TOKEN=your-atlassian-api-token

# Gmail — use an App Password (Google Account → Security → App passwords)
GMAIL_SMTP_USER=you@gmail.com
GMAIL_SMTP_PASSWORD=xxxx xxxx xxxx xxxx
WORKLOG_EMAIL_TO=you@gmail.com
# WORKLOG_EMAIL_SUBJECT=Daily Jira worklog

# Slack (optional — send_worklog_to_slack.py)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
